# Supabase project URL — find this in your Supabase dashboard under Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key — find this in your Supabase dashboard under Settings > API
# This is the safe-to-expose "anon" key (not the service_role key).
# Ensure Row Level Security (RLS) is enabled on all tables in your Supabase project.
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
